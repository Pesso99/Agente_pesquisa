{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Observation",
  "type": "object",
  "required": [
    "observation_id",
    "candidate_id",
    "captured_at",
    "source_url",
    "visible_claims",
    "artifacts"
  ],
  "properties": {
    "observation_id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "captured_at": { "type": "string" },
    "source_url": { "type": "string" },
    "page_title": { "type": ["string", "null"] },
    "visible_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "raw_html_path": { "type": ["string", "null"] },
    "raw_text_path": { "type": ["string", "null"] }
  }
}
