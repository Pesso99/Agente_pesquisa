{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report",
  "type": "object",
  "required": ["report_id", "generated_at", "summary", "sections"],
  "properties": {
    "report_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "summary": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "items"],
        "properties": {
          "title": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    }
  }
}
